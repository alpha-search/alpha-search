# =============================================================================
# Quant.OS .gitignore — Python data-science / quant-finance project
# =============================================================================

# ---------------------------------------------------------------------------
# Python build artifacts
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
wheels/
*.whl

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.env
.venv
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# ---------------------------------------------------------------------------
# IDEs and editors
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-*

# ---------------------------------------------------------------------------
# Testing / coverage / linting caches
# ---------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
noxfile.py
nox/

# ---------------------------------------------------------------------------
# Jupyter / IPython
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb
# But track versioned research notebooks under notebooks/
!notebooks/*.ipynb
profile_default/
ipython_config.py

# ---------------------------------------------------------------------------
# Data files (never commit raw data or cache)
# ---------------------------------------------------------------------------
*.csv
*.parquet
*.feather
*.db
*.duckdb
*.sqlite
*.sqlite3
*.h5
*.hdf5
*.pkl
*.pickle
.cache/

# Quant.OS local cache directory
.quant_os/

# ---------------------------------------------------------------------------
# Secrets and environment variables
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
secrets.yaml
secrets.json
*.pem
*.key

# ---------------------------------------------------------------------------
# Documentation build artifacts
# ---------------------------------------------------------------------------
site/
docs/_build/

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Streamlit
# ---------------------------------------------------------------------------
.streamlit/secrets.toml

# ---------------------------------------------------------------------------
# Model artifacts (never commit downloaded ML models)
# ---------------------------------------------------------------------------
*.pt
*.pth
*.onnx
*.safetensors
models/
checkpoints/
reports/demo/*.sqlite*
