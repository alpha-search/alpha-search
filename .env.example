# =============================================================================
# Quant.OS Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control -- it is listed in .gitignore.
#
# All values shown here are dummy placeholders. Replace with your actual
# credentials and configuration.
#
# Security rules:
#   - Never share your .env file
#   - Never paste credentials in code, notebooks, or chat
#   - Rotate API keys every 90 days
#   - Use IP whitelisting on exchange API keys when possible
# =============================================================================

# ---------------------------------------------------------------------------
# Core Application Settings
# ---------------------------------------------------------------------------
QUANT_OS_ENV=development          # Options: development, staging, production
LOG_LEVEL=INFO                    # Options: DEBUG, INFO, WARNING, ERROR
LOG_SENSITIVE=false               # When true, masks sensitive values in logs
CACHE_DIR=~/.alpha_search/cache       # Local cache directory
CACHE_ENCRYPTION=false            # Encrypt cached data at rest (prod: true)
CACHE_TTL_DAYS=30                 # Auto-expire cached market data (days)

# ---------------------------------------------------------------------------
# Data Sources -- Exchange API Keys (Paper Trading Recommended)
# ---------------------------------------------------------------------------
# All exchange API keys are OPTIONAL. Quant.OS works without them using
# built-in demo data and Yahoo Finance (no key required).
#
# For paper trading, generate keys from your exchange's testnet/sandbox.
# For live trading, ensure keys have MINIMUM required permissions.

# --- Binance (Global Crypto) ---
# Get API key: https://testnet.binance.vision/ (paper trading)
# Production: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here
BINANCE_BASE_URL=https://testnet.binance.vision  # Use testnet for development

# --- Alpaca (US Equities) ---
# Get API key: https://alpaca.markets/
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # Paper trading URL

# --- Zerodha (Indian Markets: NSE/BSE) ---
# Get API key: https://kite.trade/
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_SECRET=your_zerodha_secret_here
ZERODHA_USER_ID=your_zerodha_user_id
ZERODHA_ENCRYPTION_KEY=your_fernet_encryption_key  # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Interactive Brokers (Optional) ---
IB_GATEWAY_HOST=127.0.0.1
IB_GATEWAY_PORT=7497            # 7496 for TWS, 7497 for IB Gateway
IB_CLIENT_ID=1

# ---------------------------------------------------------------------------
# News & Sentiment Data (Optional)
# ---------------------------------------------------------------------------
# NewsAPI: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# Alpha Vantage (fundamental data): https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alphavantage_key_here

# Financial Modeling Prep: https://site.financialmodelingprep.com/developer/docs/pricing
FMP_API_KEY=your_fmp_api_key_here

# ---------------------------------------------------------------------------
# Redis -- Task Queue & Caching
# ---------------------------------------------------------------------------
# Required for: multi-agent task orchestration, token storage, rate limiting
# Local install: https://redis.io/docs/getting-started/installation/
# Docker: docker run -d --name redis -p 6379:6379 redis:7-alpine
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                     # Set a strong password in production
REDIS_DB=0
REDIS_SSL=false                     # Set to true in production

# ---------------------------------------------------------------------------
# DuckDB -- Structured Agent Memory
# ---------------------------------------------------------------------------
# DuckDB is embedded -- no server needed. This configures the database file
# location for agent state, backtest results, and task history.
AGENT_DB_PATH=~/.alpha_search/agents/memory.db

# ---------------------------------------------------------------------------
# Vector Memory (Optional -- ChromaDB)
# ---------------------------------------------------------------------------
# Set to true to enable semantic search over research papers and agent logs.
# Requires: pip install chromadb
QUANT_OS_VECTOR_MEMORY_ENABLED=false
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_AUTH_TOKEN=                  # Set if ChromaDB authentication is enabled
AGENT_VECTOR_DB_PATH=~/.alpha_search/agents/vector_db

# ---------------------------------------------------------------------------
# Agent System Configuration
# ---------------------------------------------------------------------------
AGENT_WORKERS=4                     # Number of concurrent agent workers
AGENT_TASK_TIMEOUT=300              # Task timeout in seconds (5 minutes)
AGENT_HEARTBEAT_INTERVAL=30         # Health check interval in seconds
AGENT_JOURNAL_DIR=~/.alpha_search/agents/journals

# ---------------------------------------------------------------------------
# Web API / Dashboard (Phase 3 -- Optional)
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                       # Increase for production (typically CPU count)

# JWT Authentication
JWT_SECRET_KEY=generate_with_openssl_rand_base64_32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth 2.0 (GitHub)
GITHUB_OAUTH_CLIENT_ID=your_github_oauth_app_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_app_secret

# OAuth 2.0 (Google)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# CORS (Cross-Origin Resource Sharing)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://alpha-search.dev
CORS_ALLOWED_METHODS=GET,POST

# Security Headers
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE=31536000

# ---------------------------------------------------------------------------
# Audit Logging
# ---------------------------------------------------------------------------
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=~/.alpha_search/logs/audit.log
AUDIT_LOG_RETENTION_DAYS=90

# ---------------------------------------------------------------------------
# Monitoring & Alerting (Optional)
# ---------------------------------------------------------------------------
# Prometheus metrics endpoint
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Sentry error tracking: https://sentry.io/
SENTRY_DSN=                         # Leave empty to disable
SENTRY_ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Development Only Settings
# ---------------------------------------------------------------------------
# These should NOT be set in production
DEBUG=true                          # Enable debug mode (dev only: stack traces in responses)
AUTO_RELOAD=false                   # Auto-reload on code changes (dev only)
SKIP_AUTH=false                     # Skip authentication (dev/testing only)

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
# Test-specific overrides
TEST_CACHE_DIR=/tmp/alpha_search_test_cache
TEST_REDIS_DB=15                    # Use separate Redis DB for tests

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
# Enable/disable experimental features
FEATURE_WALK_FORWARD_OPTIMIZATION=false
FEATURE_LIVE_PAPER_TRADING=false
FEATURE_MULT_TIME_FRAME=false
FEATURE_PORTFOLIO_OPTIMIZATION=false
